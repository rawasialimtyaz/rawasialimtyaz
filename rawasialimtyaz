<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>شركة رواسي الامتياز للإستقدام | جاري التحويل</title>
    <meta http-equiv="refresh" content="5; url=tel:920008490">
    <style>
        :root {
            --brand-green: #0a7c3e; /* درجة الأخضر من اللوجو */
            --brand-blue: #1c8ac9;  /* درجة الأزرق من اللوجو */
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background-color: #f8fcfb;
            color: #333;
            text-align: center;
            overflow: hidden;
        }

        .container {
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            max-width: 450px;
            width: 85%;
            position: relative;
            border-top: 5px solid var(--brand-green);
            border-bottom: 5px solid var(--brand-blue);
        }

        /* تنسيق اللوجو */
        .logo-img {
            max-width: 180px;
            margin-bottom: 20px;
        }

        h2 {
            color: var(--brand-green);
            margin-bottom: 10px;
            font-size: 1.4rem;
        }

        p.subtitle {
            color: #666;
            font-size: 1.1rem;
            margin-bottom: 25px;
        }

        /* الأنيميشن (Motion Graphics) */
        .pulse-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            margin: 30px 0;
        }

        .pulse-dot {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            animation: bounce 1.5s infinite ease-in-out both;
        }

        .pulse-dot:nth-child(1) { background-color: var(--brand-blue); animation-delay: -0.32s; }
        .pulse-dot:nth-child(2) { background-color: var(--brand-green); animation-delay: -0.16s; }
        .pulse-dot:nth-child(3) { background-color: var(--brand-blue); }

        @keyframes bounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }

        /* شريط التحميل */
        .progress-bar-container {
            width: 100%;
            height: 6px;
            background-color: #e0e0e0;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 15px;
        }

        .progress-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--brand-blue), var(--brand-green));
            transition: width 1s linear;
        }

        /* الزر الاحتياطي */
        .btn-call {
            display: inline-block;
            margin-top: 15px;
            padding: 12px 35px;
            background: linear-gradient(45deg, var(--brand-green), var(--brand-blue));
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: bold;
            font-size: 1.1rem;
            box-shadow: 0 4px 15px rgba(28, 138, 201, 0.4);
            transition: transform 0.3s ease;
        }

        .btn-call:hover {
            transform: scale(1.05);
        }

        .footer {
            margin-top: 30px;
            font-size: 0.85rem;
            color: #999;
        }
    </style>
</head>
<body>

    <div class="container">
        <img src="LOGO_WEB.png" alt="شركة رواسي الامتياز للإستقدام" class="logo-img">
        
        <h2>جاري تحويلك إلى أحد ممثلي خدمة العملاء...</h2>
        <p class="subtitle">سيتم بدء الاتصال خلال <strong id="countdown">5</strong> ثوانٍ</p>

        <div class="pulse-container">
            <div class="pulse-dot"></div>
            <div class="pulse-dot"></div>
            <div class="pulse-dot"></div>
        </div>

        <div class="progress-bar-container">
            <div class="progress-bar" id="progressBar"></div>
        </div>

        <a href="tel:920008490" class="btn-call" id="callBtn" style="display: none;">اضغط هنا للاتصال يدوياً 📞</a>
    </div>

    <div class="footer">
        &copy; <span id="year"></span> شركة رواسي الامتياز للإستقدام. جميع الحقوق محفوظة.
    </div>

    <script>
        // ضبط السنة تلقائياً في الفوتر
        document.getElementById("year").textContent = new Date().getFullYear();

        // برمجة العداد التنازلي وشريط التحميل
        let timeLeft = 5;
        const countdownEl = document.getElementById("countdown");
        const progressBarEl = document.getElementById("progressBar");
        const callBtn = document.getElementById("callBtn");

        // تشغيل شريط التحميل (من 0 لـ 100% خلال 5 ثواني)
        setTimeout(() => {
            progressBarEl.style.width = "100%";
        }, 100); 

        const timer = setInterval(() => {
            timeLeft--;
            countdownEl.textContent = timeLeft;

            if (timeLeft <= 0) {
                clearInterval(timer);
                // إظهار الزر في حال المتصفح منع التحويل التلقائي
                callBtn.style.display = "inline-block";
                // تنفيذ الاتصال برمجياً
                window.location.href = "tel:920008490";
            }
        }, 1000); // تحديث كل ثانية
    </script>

</body>
</html>
