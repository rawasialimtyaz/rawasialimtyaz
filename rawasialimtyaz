<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>شركة رواسي الامتياز للإستقدام | تواصل معنا</title>
    <style>
        /* تصميم فلات (Flat Design) بسيط ومستقر 100% */
        body {
            font-family: Arial, Tahoma, sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f4f7f6;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        .container {
            background-color: #ffffff;
            width: 100%;
            max-width: 400px;
            padding: 30px 20px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            text-align: center;
            border-top: 5px solid #0a7c3e; /* لون اللوجو الأخضر */
            border-bottom: 5px solid #1c8ac9; /* لون اللوجو الأزرق */
        }

        .brand-name {
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 5px;
            line-height: 1.5;
        }

        .text-green { color: #0a7c3e; }
        .text-blue { color: #1c8ac9; }

        .subtitle {
            color: #666;
            font-size: 14px;
            margin-bottom: 25px;
        }

        /* زر الرقم الموحد */
        .btn-main {
            display: block;
            background-color: #0a7c3e;
            color: #ffffff;
            text-decoration: none;
            padding: 15px;
            border-radius: 8px;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 25px;
            border: 2px solid #0a7c3e;
        }

        .btn-main:active {
            background-color: #085e2f;
        }

        .reps-section h3 {
            font-size: 15px;
            color: #444;
            margin-bottom: 15px;
            border-top: 1px solid #eee;
            padding-top: 20px;
        }

        .reps-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* أزرار المناديب */
        .btn-rep {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #ffffff;
            color: #333;
            text-decoration: none;
            padding: 12px 15px;
            border: 1px solid #dcdcdc;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
        }

        .btn-rep:hover, .btn-rep:active {
            border-color: #1c8ac9;
            color: #1c8ac9;
            background-color: #f0f8ff;
        }

        .footer {
            margin-top: 30px;
            font-size: 12px;
            color: #999;
        }
    </style>
</head>
<body>

